<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="#FFD600">

    <!-- ၁။ Logo ကို Background layer အနေနဲ့ အကြီးကြီးထားပါမယ် -->
    <ImageView
        android:layout_width="280dp"
        android:layout_height="160dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="-40dp"
        android:alpha="0.3"
        android:scaleType="fitCenter"
        android:src="@mipmap/royal_logo_foreground" />

    <!-- ၂။ စာသားတွေကို အပေါ် layer ကနေ တင်ပါမယ် (အောက်ခြေမှာ စုထားပါတယ်) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title (Solid Red) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REX Checking System"
            android:textColor="#FF0000"
            android:textSize="20sp"
            android:textStyle="bold"
            android:shadowColor="#40000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />

        <!-- User ID (Solid Red) -->
        <TextView
            android:id="@+id/tvUserAccountID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="REX-XXXX-XXXX"
            android:textColor="#CC0000"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>