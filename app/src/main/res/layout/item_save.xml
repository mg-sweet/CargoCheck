<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface"> <!-- Card နောက်ခံကို Theme အလိုက်ပြောင်းရန် -->

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- စာသားများရှိမည့် အပိုင်း -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_toStartOf="@+id/btnDelete">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"/> <!-- ရက်စွဲကို မီးခိုးဖျော့ (Dark မှာ အဖြူပိန်) -->

            <TextView
                android:id="@+id/tvLabelCargo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargo Result:"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvSavedCargo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No Error"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginTop="2dp" /> <!-- စာသားကို Dark Mode မှာ အဖြူရောင်ပြောင်းမည် -->

            <TextView
                android:id="@+id/tvLabelOb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OB Result:"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvSavedOb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No Error"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginTop="2dp" /> <!-- စာသားကို Dark Mode မှာ အဖြူရောင်ပြောင်းမည် -->
        </LinearLayout>

        <!-- ဖျက်မည့်ခလုတ် -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#D32F2F" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>