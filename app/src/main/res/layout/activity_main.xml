<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    > <!-- Theme အလိုက် ပြောင်းမည့် နောက်ခံ -->

    <!-- အဓိက Screen (Main Content) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:id="@+id/main"
        android:padding="5dp">

        <!-- ၁။ Premium Top Bar (Company Colors: Yellow & Red) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="15dp"
            app:cardBackgroundColor="#FFD600"> <!-- အမြဲတမ်း အဝါရောင် (Company Identity) -->

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="REX Checking System"
                    android:shadowColor="#40000000"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:shadowDx="3"
                    android:shadowDy="3"
                    android:shadowRadius="3"
                    android:textColor="#FF0000"/> <!-- အနီရောင်စာသား -->

                <ImageButton
                    android:id="@+id/btnMenuToggle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_gear"
                    app:tint="#FF0000"/> <!-- အနီရောင် Gear Icon -->
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ၂။ Buttons Area (အလယ်ဗဟို ကျသွားအောင် ScrollView နဲ့ အုပ်ထားပါတယ်) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"

                android:padding="20dp">

                <!-- IB နဲ့ OB Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnIbChecking"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:text="IB\nChecking"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#2E7D32"
                        app:cornerRadius="20dp"
                        app:elevation="4dp"
                        android:layout_marginEnd="8dp"
                        app:icon="@drawable/ic_consignment_in"
                        app:iconGravity="top"
                        app:iconPadding="8dp"
                        app:iconSize="32dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnObChecking"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:text="OB\nChecking"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#EF6C00"
                        app:cornerRadius="20dp"
                        app:elevation="4dp"
                        android:layout_marginStart="8dp"
                        app:icon="@drawable/ic_consignment_out"
                        app:iconGravity="top"
                        app:iconPadding="8dp"
                        app:iconSize="32dp"/>
                </LinearLayout>

                <!-- QR Generator Button (Full Width) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQrGenerator"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:text="QR Generator"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#1565C0"
                    app:cornerRadius="20dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_qr_generator"
                    app:iconPadding="12dp"
                    app:iconSize="32dp"
                    app:iconTint="#FFFFFF" />

                <!-- အောက်ခြေတွင် ကုမ္ပဏီ နာမည်လေး ထည့်ပေးထားပါသည် -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="140dp"
                    android:text="Royal Express Myanmar"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_gravity="center_horizontal"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Drawer Navigation -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="?attr/colorPrimary"
        app:itemTextColor="?android:attr/textColorPrimary" />

</androidx.drawerlayout.widget.DrawerLayout>